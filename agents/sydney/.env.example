# ─── LiveKit Cloud (required) ─────────────────────────────────────────
# Sydney runs LLM/STT/TTS through LiveKit Cloud Inference — these are the
# ONLY required keys for the agent itself. Provider billing flows through
# your LiveKit project; no separate OpenAI / Deepgram / Cartesia accounts
# required.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Optional: SIP outbound transfer routing ──────────────────────────
# When BOTH SIP_OUTBOUND_TRUNK_ID AND the matching ESCALATION_<reason>_PHONE
# are set, transfer_to_human dials a real on-call human. Without these,
# transfer_to_human falls back to a redacted log line so the demo still
# works without escalation numbers configured. Leaving these unset
# keeps Sydney in mock-transfer mode (logs the request, doesn't dial).
SIP_OUTBOUND_TRUNK_ID=
ESCALATION_EMERGENCY_PHONE=
ESCALATION_WARRANTY_PHONE=
ESCALATION_SALES_PHONE=
ESCALATION_GENERAL_PHONE=
# Caller-ID we present to the on-call human when bridging a transfer.
# Must be an E.164 number the project owns. Defaults to Noland's main
# line so the human sees "incoming from Noland's main."
TRANSFER_CALLER_ID=+13219851104

# ─── Outbound caller-ID Sydney presents on follow-up calls ────────────
# When Sydney calls a homeowner after a /quote submit, this number
# shows on the homeowner's screen. Setting to +13219851104 (Noland's
# main published line) means homeowners see the brand's familiar
# number — maximizes answer rate.
#
# REQUIRES: the outbound SIP trunk must be authorized to use
# +13219851104 as caller-ID. If Twilio rejects with SIP 403 "Caller
# ID unauthorized", either (a) verify the number on the trunk in
# Twilio Console, or (b) fall back to the trunk's primary DID
# +14072890294 by setting SYDNEY_OUTBOUND_CALLER_ID=+14072890294 here.
SYDNEY_OUTBOUND_CALLER_ID=+13219851104

# Must match WorkerOptions(agent_name=...) in agent.py when posting
# tool_fired rows to /api/agent/events (default: sydney).
# SYDNEY_AGENT_NAME_EVENTS=sydney

# ─── Optional: hard call limits ───────────────────────────────────────
# Defense-in-depth against runaway calls (stuck caller, malicious looper).
# Defaults are sensible but tune if you observe legitimate calls hitting them.
SYDNEY_MAX_CALL_DURATION_SEC=900    # 15 min hard cap
SYDNEY_MAX_TURNS=80                 # 80 user turns ≈ 8-10 min of normal talk

# ─── JobNimbus CRM integration (Noland's production) ──────────────────
# When JOBNIMBUS_API_KEY is set, book_inspection + log_lead route
# through agents/sydney/jobnimbus.py to create real Contact + Job
# records. Otherwise they fall back to MOCK mode (still capture lead
# via dashboard event + webhook so nothing gets dropped silently).
#
# Get the API key from JobNimbus → Settings → API.
# Base URL defaults to https://app.jobnimbus.com/api1 — override only
# if Noland's runs on a different JN region.
# JOBNIMBUS_API_KEY=
# JOBNIMBUS_BASE_URL=https://app.jobnimbus.com/api1

# ─── Optional: prompt version override ────────────────────────────────
# PROMPT_VERSION=v1 falls back to the original prompt; default v2 is the
# 5-phase Cassie-style structure.
PROMPT_VERSION=v2

# ─── Optional: Rime mistv3 speed override ─────────────────────────────
# Default 1.0 matches Cassie + Deedy. Override only if a specific deploy
# needs a different pace (0.95 = slower / more deliberate; 1.05 = a bit
# snappier). Rime mistv3 uses `speed_alpha`, NOT the Cartesia `speed`
# parameter — they're separate knobs that don't interchange.
# SYDNEY_RIME_SPEED_ALPHA=1.0

# ─── Optional: Spanish brand voice (A2) ───────────────────────────────
# Spanish calls default to rime/arcana voice="luna" — Rime's arcana
# model is multilingual and speaks Spanish natively. This is the right
# primary, NOT a degraded fallback.
#
# Setting SYDNEY_TTS_VOICE_ID_ES adds a Cartesia ES voice as a second-
# tier fallback under arcana for vendor-diversity / brand-voice
# unification across languages. Optional. Pick from
# https://play.cartesia.ai/voices when you want a specific Latina
# voice. English calls use Rime mistv3 "moraine" matching Cassie +
# Deedy — not this voice ID.
# SYDNEY_TTS_VOICE_ID_ES=

# ─── Local-dev ONLY — direct provider keys (do NOT set in LK Cloud) ───
# Only needed if you opt out of LK Cloud Inference for local console mode.
# Unset in production — LiveKit Cloud routes through its inference endpoint.
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
