{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/storm-pulse",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/competitor-scrape",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/podium-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/podium-abandoners",
      "schedule": "0 * * * *"
    }
  ]
}
